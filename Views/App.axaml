<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="ReviewG33k.Views.App"
             Name="ReviewG33k"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <Color x:Key="Bg0">#070A10</Color>
    <Color x:Key="Bg1">#0B1020</Color>
    <Color x:Key="Bg2">#0F1730</Color>
    <Color x:Key="Text0">#E8F0FF</Color>
    <Color x:Key="Text1">#9FB0D0</Color>

    <Color x:Key="NeonCyan">#00E5FF</Color>
    <Color x:Key="NeonMagenta">#FF3DF2</Color>
    <Color x:Key="NeonAmber">#FFD166</Color>
    <Color x:Key="NeonRed">#FF4D6D</Color>

    <SolidColorBrush x:Key="BrushBg0" Color="{StaticResource Bg0}" />
    <SolidColorBrush x:Key="BrushBg1" Color="{StaticResource Bg1}" />
    <SolidColorBrush x:Key="BrushBg2" Color="{StaticResource Bg2}" />
    <SolidColorBrush x:Key="BrushText0" Color="{StaticResource Text0}" />
    <SolidColorBrush x:Key="BrushText1" Color="{StaticResource Text1}" />

    <SolidColorBrush x:Key="BrushNeonCyan" Color="{StaticResource NeonCyan}" />
    <SolidColorBrush x:Key="BrushNeonMagenta" Color="{StaticResource NeonMagenta}" />
    <SolidColorBrush x:Key="BrushNeonAmber" Color="{StaticResource NeonAmber}" />
    <SolidColorBrush x:Key="BrushNeonRed" Color="{StaticResource NeonRed}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource NeonCyan}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#5EF0FF" />
  </Application.Resources>

  <Application.Styles>
    <materialIcons:MaterialIconStyles />
    <FluentTheme />
    <dialogHostAvalonia:DialogHostStyles />

    <Style Selector="Window">
      <Setter Property="Background" Value="{StaticResource BrushBg0}" />
    </Style>

    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
    </Style>

    <Style Selector="Border.mainGlassPanel">
      <Setter Property="Background" Value="#DC07101A" />
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="BorderBrush" Value="#3F87B8D8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="0 18 40 0 #40000000" />
    </Style>

    <Style Selector="TextBlock.mainHeroEyebrow">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#A0BFE0FF" />
      <Setter Property="LetterSpacing" Value="2" />
    </Style>

    <Style Selector="TextBlock.mainHeroTitle">
      <Setter Property="FontSize" Value="36" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#F3FAFF" />
    </Style>

    <Style Selector="TextBlock.mainHeroBody">
      <Setter Property="FontSize" Value="17" />
      <Setter Property="Foreground" Value="#E1EEFF" />
    </Style>

    <Style Selector="TextBlock.mainSectionTitle">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F3FAFF" />
    </Style>

    <Style Selector="TextBlock.mainSectionHint">
      <Setter Property="Foreground" Value="#B4C5D8" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
          <GradientStop Color="#2200E5FF" Offset="0" />
          <GradientStop Color="#1200E5FF" Offset="1" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="{StaticResource BrushNeonCyan}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.sevPill">
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="10,3" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#101728" />
      <Setter Property="BorderBrush" Value="#2A3A60" />
    </Style>

    <Style Selector="Border.sevImportant">
      <Setter Property="BorderBrush" Value="{StaticResource BrushNeonRed}" />
      <Setter Property="BoxShadow" Value="0 0 14 0 #55FF4D6D" />
    </Style>

    <Style Selector="Border.sevSuggestion">
      <Setter Property="BorderBrush" Value="{StaticResource BrushNeonAmber}" />
      <Setter Property="BoxShadow" Value="0 0 12 0 #44FFD166" />
    </Style>

    <Style Selector="Button">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
      <Setter Property="Background" Value="#0E1A2B" />
      <Setter Property="BorderBrush" Value="#2A3A60" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="BorderBrush" Value="{StaticResource BrushNeonCyan}" />
      <Setter Property="Background" Value="#13243A" />
    </Style>

    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{StaticResource BrushNeonCyan}" />
      <Setter Property="BorderBrush" Value="{StaticResource BrushNeonCyan}" />
      <Setter Property="Foreground" Value="#081018" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.accent:pointerover">
      <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
    </Style>

    <Style Selector="Button.neon">
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Background" Value="#0E1A2B" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="#2A3A60" />
    </Style>

    <Style Selector="Button.neon:pointerover">
      <Setter Property="BorderBrush" Value="{StaticResource BrushNeonCyan}" />
      <Setter Property="Background" Value="#13243A" />
    </Style>

    <Style Selector="ContextMenu">
      <Setter Property="Background" Value="#F20A1320" />
      <Setter Property="BorderBrush" Value="#5A87B8D8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6" />
    </Style>

    <Style Selector="MenuItem">
      <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="MenuItem:pointerover">
      <Setter Property="Background" Value="#1E163148" />
    </Style>

    <Style Selector="MenuItem:selected">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
          <GradientStop Color="#2200E5FF" Offset="0" />
          <GradientStop Color="#1200E5FF" Offset="1" />
        </LinearGradientBrush>
      </Setter>
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
      <Setter Property="Background" Value="#0E1A2B" />
      <Setter Property="BorderBrush" Value="#2A3A60" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,8" />
    </Style>

    <Style Selector="ComboBox:pointerover">
      <Setter Property="BorderBrush" Value="{StaticResource BrushNeonCyan}" />
      <Setter Property="Background" Value="#13243A" />
    </Style>

    <Style Selector="ComboBoxItem">
      <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
      <Setter Property="Background" Value="#F20A1320" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="ComboBoxItem:pointerover">
      <Setter Property="Background" Value="#1E163148" />
    </Style>

    <Style Selector="ComboBoxItem:selected">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
          <GradientStop Color="#2200E5FF" Offset="0" />
          <GradientStop Color="#1200E5FF" Offset="1" />
        </LinearGradientBrush>
      </Setter>
      <Setter Property="BorderBrush" Value="{StaticResource BrushNeonCyan}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Foreground" Value="{StaticResource BrushText0}" />
      <Setter Property="Background" Value="{StaticResource BrushBg2}" />
      <Setter Property="BorderBrush" Value="#2A3A60" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,8" />
    </Style>

  </Application.Styles>
</Application>
