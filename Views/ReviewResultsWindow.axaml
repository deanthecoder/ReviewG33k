<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="ReviewG33k.Views.ReviewResultsWindow"
        Width="980"
        Height="620"
        MinWidth="700"
        MinHeight="420"
        Title="Review Results">
    <Grid Margin="16"
          RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock x:Name="SummaryTextBlock"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Text="Review issues" />

        <Grid Grid.Row="1"
              Margin="0,12,0,6"
              ColumnDefinitions="34,90,*,Auto">
            <TextBlock Grid.Column="1"
                       FontWeight="SemiBold"
                       Text="Severity" />
            <TextBlock Grid.Column="2"
                       Margin="8,0,0,0"
                       FontWeight="SemiBold"
                       Text="Issue" />
        </Grid>

        <Grid Grid.Row="2"
              RowDefinitions="*,Auto"
              MinHeight="220">
            <Border Grid.Row="0"
                    MinHeight="140"
                    BorderBrush="{DynamicResource ZoneBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <ListBox x:Name="ResultsListBox"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                        <Grid Margin="0,1"
                              Background="Transparent"
                              ColumnDefinitions="34,90,*,Auto">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Binding UntickSameTypeMenuHeader}"
                                                  Click="UntickSameTypeMenuItem_OnClick" />
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <CheckBox Grid.Column="0"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsIncluded}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Text="{Binding SeverityText}" />
                                <StackPanel Grid.Column="2"
                                            Margin="8,2,8,2"
                                            Spacing="1">
                                    <TextBlock Text="{Binding IssueSummary}"
                                               Foreground="{Binding IssueForeground}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               ToolTip.Tip="{Binding IssueFull}" />
                                    <TextBlock Text="{Binding IssueLocation}"
                                               Foreground="{Binding IssueLocationForeground}"
                                               FontSize="11"
                                               HorizontalAlignment="Left"
                                               TextAlignment="Left"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               ToolTip.Tip="{Binding IssueLocation}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3"
                                            Margin="8,0,8,0"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Spacing="6">
                                    <Button Width="78"
                                            Click="FixFindingButton_OnClick"
                                            IsVisible="{Binding ShowFixButton}"
                                            IsEnabled="{Binding CanFixActive}"
                                            ToolTip.Tip="{Binding FixToolTip}"
                                            Content="Fix" />
                                    <Button Width="78"
                                            Click="CommentFindingButton_OnClick"
                                            IsVisible="{Binding ShowCommentButton}"
                                            IsEnabled="{Binding CanCommentActive}"
                                            ToolTip.Tip="{Binding CommentToolTip}"
                                            Content="Comment" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    BorderBrush="{DynamicResource ZoneBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="PreviewHeaderTextBlock"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="Preview" />
                        <Button x:Name="OpenSelectedButton"
                                Grid.Column="1"
                                Margin="8,0,0,6"
                                Width="110"
                                Click="OpenSelectedButton_OnClick"
                                Content="Open Selected" />
                    </Grid>
                    <TextBox x:Name="PreviewTextBox"
                             Grid.Row="1"
                             Height="230"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas, Courier New, monospace"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3"
              Margin="0,10,0,0"
              ColumnDefinitions="Auto,Auto,*,Auto">
            <Button x:Name="ToggleAllButton"
                    Grid.Column="0"
                    Width="110"
                    Click="ToggleAllButton_OnClick"
                    Content="Toggle All" />
            <Button x:Name="ExportToClipboardButton"
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Width="150"
                    Click="ExportToClipboardButton_OnClick"
                    Content="Export To Clipboard" />
            <Button x:Name="CommentSelectedButton"
                    Grid.Column="3"
                    Width="140"
                    Click="CommentSelectedButton_OnClick"
                    Content="Comment Selected" />
        </Grid>
    </Grid>
</Window>
