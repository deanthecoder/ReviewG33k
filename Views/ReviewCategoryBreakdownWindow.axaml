<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:ReviewG33k.Views.Controls"
        xmlns:viewModels="clr-namespace:ReviewG33k.ViewModels"
        mc:Ignorable="d"
        x:Class="ReviewG33k.Views.ReviewCategoryBreakdownWindow"
        Width="860"
        Height="560"
        MinWidth="760"
        MinHeight="500"
        Title="Issue Categories">
    <Design.DataContext>
        <viewModels:ReviewResultsWindowViewModel />
    </Design.DataContext>

    <Grid>
        <Image Source="/Assets/child-window-bg.jpg"
               Stretch="UniformToFill" />
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#B2040A13" Offset="0" />
                    <GradientStop Color="#90040A13" Offset="0.4" />
                    <GradientStop Color="#C8040911" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="24"
              RowDefinitions="Auto,Auto,*">
            <StackPanel Grid.Row="0"
                        Margin="0,6,0,18"
                        Spacing="5">
                <TextBlock Classes="mainHeroEyebrow"
                           Text="ISSUE CATEGORIES" />
                <TextBlock Classes="mainSectionTitle"
                           FontSize="28"
                           Text="Breakdown" />
                <TextBlock Opacity="0.85"
                           Text="{Binding CategoryBreakdownText}" />
            </StackPanel>

            <Grid Grid.Row="2"
                  ColumnDefinitions="1.15*,0.95*">
                <Border Grid.Column="0"
                        Classes="mainGlassPanel"
                        Margin="0,0,10,0"
                        Padding="18">
                    <Grid>
                        <controls:PieChartControl Segments="{Binding CategoryFilters}" />
                        <Border Width="118"
                                Height="118"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#08111D"
                                BorderBrush="#2A3A60"
                                BorderThickness="1.5"
                                CornerRadius="59">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Text="{Binding CategoryBreakdownTotalText}" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           Opacity="0.72"
                                           Text="issues" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="mainGlassPanel"
                        Margin="10,0,0,0"
                        Padding="16">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Classes="mainSectionTitle"
                                   FontSize="18"
                                   Text="Visible Categories" />

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,12,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CategoryFilters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:ReviewCategoryFilterItemViewModel">
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="#780C1622"
                                                BorderBrush="#2D4562"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Opacity="{Binding RowOpacity}">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                                                <StackPanel Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Border Width="12"
                                                            Height="12"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding ColorBrush}"
                                                            BoxShadow="0 0 10 0 #33000000"
                                                            CornerRadius="6" />
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding CategoryName}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CountText}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
