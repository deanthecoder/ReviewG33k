<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:ReviewG33k.Views.Controls"
        xmlns:viewModels="clr-namespace:ReviewG33k.ViewModels"
        mc:Ignorable="d"
        x:Class="ReviewG33k.Views.ReviewCategoryBreakdownWindow"
        Width="860"
        Height="560"
        MinWidth="760"
        MinHeight="500"
        Title="Issue Categories">
    <Design.DataContext>
        <viewModels:ReviewCategoryFilterItemViewModel />
    </Design.DataContext>

    <Grid Margin="18"
          RowDefinitions="Auto,Auto,*">
        <TextBlock Classes="sectionTitle"
                   Text="Issue Category Breakdown" />

        <TextBlock Grid.Row="1"
                   Margin="0,6,0,16"
                   Opacity="0.85"
                   Text="{Binding CategoryBreakdownText}" />

        <Grid Grid.Row="2"
              ColumnDefinitions="1.15*,0.95*">
            <Border Grid.Column="0"
                    Classes="neonHero"
                    Margin="0,0,9,0"
                    Padding="18"
                    BoxShadow="0 18 38 0 #30000000, 0 0 22 0 #4400E5FF">
                <Grid RowDefinitions="*,Auto">
                    <Grid>
                        <controls:PieChartControl Segments="{Binding CategoryFilters}" />
                        <Border Width="118"
                                Height="118"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#08111D"
                                BorderBrush="#2A3A60"
                                BorderThickness="1.5"
                                CornerRadius="59">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="2">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Text="{Binding CategoryBreakdownTotalText}" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="12"
                                           Opacity="0.72"
                                           Text="issues" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Classes="neonFrame"
                    Margin="9,0,0,0"
                    Padding="16">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock FontWeight="SemiBold"
                               Text="Visible Categories" />

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CategoryFilters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            Background="#101728"
                                            BorderBrush="#233653"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Opacity="{Binding RowOpacity}">
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              Margin="0">
                                            <CheckBox Grid.Column="0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                                            <StackPanel Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        Spacing="3">
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Border Width="12"
                                                            Height="12"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding ColorBrush}"
                                                            BoxShadow="0 0 10 0 #33000000"
                                                            CornerRadius="6" />
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding CategoryName}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CountText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
