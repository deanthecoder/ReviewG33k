<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:viewModels="clr-namespace:ReviewG33k.ViewModels"
        mc:Ignorable="d"
        x:Name="MainWindowRoot"
        x:Class="ReviewG33k.Views.MainWindow"
        Width="980" Height="700"
        MinWidth="880" MinHeight="520"
        Icon="/Assets/app.ico"
        Title="ReviewG33k">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>

    <dialogHostAvalonia:DialogHost x:Name="Host"
                                   OverlayBackground="#AA000000">
        <Grid Margin="18" RowDefinitions="Auto,Auto,*">
            <Border Grid.Row="0"
                    Margin="0,0,0,12"
                    Classes="zone neonFrame"
                    Background="{DynamicResource ZonePrimaryBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Classes="sectionTitle"
                               Text="ReviewG33k" />
                    <TextBlock
                        Text="Prepare Bitbucket pull requests for local review by creating an isolated checkout without changing your current working repo."
                        Opacity="0.9"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,0,0,12"
                    Classes="zone neonFrame"
                    Background="{DynamicResource ZoneSecondaryBrush}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Grid.IsSharedSizeScope="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"
                                          SharedSizeGroup="FormLabelColumn" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,12,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Text="Repo Root Folder:" />
                    <TextBox x:Name="RepositoryRootTextBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             MinWidth="480"
                             Text="{Binding RepositoryRootPath, Mode=TwoWay}"
                             Watermark="Example: C:\source" />
                    <Button Grid.Row="0"
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            Classes="neon"
                            Command="{Binding BrowseRepositoryRootCommand}"
                            ToolTip.Tip="Browse folder&#10;Used as the parent location for local clones/worktrees.">
                        <materialIcons:MaterialIcon Width="18"
                                                    Height="18"
                                                    Kind="FolderSearchOutline" />
                    </Button>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,12,0"
                               Text="Scan Scope:" />

                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,4">
                        <ComboBox x:Name="ScanScopeComboBox"
                                  MinWidth="260"
                                  SelectedIndex="{Binding ScanScopeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Changed lines" />
                            <ComboBoxItem Content="Full modified files" />
                        </ComboBox>
                        <Button x:Name="ScanScopeInfoButton"
                                Margin="4,0"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip.Tip="{Binding ScanScopeInfoTooltip}">
                            <materialIcons:MaterialIcon Width="18" Height="18"
                                                        Foreground="#3B82F6"
                                                        Kind="InformationOutline" />
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,12,0"
                               Text="Review Mode:" />

                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
                        <ComboBox x:Name="ReviewModeComboBox"
                                  MinWidth="260"
                                  SelectedIndex="{Binding ReviewModeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Pull Request" />
                            <ComboBoxItem Content="Local committed changes" />
                            <ComboBoxItem Content="Local uncommitted changes" />
                        </ComboBox>
                        <Button x:Name="ReviewModeInfoButton"
                                Margin="4,0"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip.Tip="{Binding ReviewModeInfoTooltip}">
                            <materialIcons:MaterialIcon Width="18" Height="18"
                                                        Foreground="#3B82F6"
                                                        Kind="InformationOutline" />
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="PullRequestUrlLabelTextBlock"
                               Grid.Row="3"
                               Grid.Column="0"
                               Margin="0,10,12,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ShowPullRequestInputs}"
                               Text="Pull Request:" />
                    <TextBox x:Name="PullRequestUrlTextBox"
                             Grid.Row="3"
                             Grid.Column="1"
                             Margin="0,8,0,0"
                             DragDrop.AllowDrop="True"
                             IsVisible="{Binding ShowPullRequestInputs}"
                             Text="{Binding PullRequestUrl, Mode=TwoWay}"
                             Watermark="Paste or drop a Bitbucket PR URL" />
                    <Button x:Name="OpenPullRequestButton"
                            Grid.Row="3"
                            Grid.Column="2"
                            Margin="10,10,0,0"
                            Classes="neon"
                            Padding="12,8"
                            Command="{Binding OpenPullRequestCommand}"
                            IsVisible="{Binding ShowPullRequestInputs}"
                            IsEnabled="{Binding CanOpenPullRequest}"
                            ToolTip.Tip="Open pull request URL">
                        <materialIcons:MaterialIcon Width="18"
                                                    Height="18"
                                                    Kind="Web" />
                    </Button>

                    <TextBlock x:Name="PullRequestMetadataTextBlock"
                               Grid.Row="4"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               IsVisible="{Binding ShowPullRequestMetadata}"
                               Text="{Binding PullRequestMetadataText}"
                               TextWrapping="Wrap" />

                    <Grid x:Name="LocalReviewOptionsGrid"
                          Grid.Row="5"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="0,12,0,0"
                          IsVisible="{Binding !ShowPullRequestInputs}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"
                                              SharedSizeGroup="FormLabelColumn" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,12,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text="Local Repo:" />
                        <TextBox x:Name="LocalRepositoryFolderTextBox"
                                 Grid.Column="1"
                                 MinWidth="360"
                                 Text="{Binding LocalRepositoryPath, Mode=TwoWay}"
                                 Watermark="Example: C:\source\MyRepo" />
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Classes="neon"
                                Command="{Binding BrowseLocalRepositoryCommand}"
                                ToolTip.Tip="Browse folder">
                            <materialIcons:MaterialIcon Width="18"
                                                        Height="18"
                                                        Kind="FolderSearchOutline" />
                        </Button>
                        <TextBlock x:Name="LocalBaseBranchLabelTextBlock"
                                   Grid.Column="3"
                                   Margin="14,0,8,0"
                                   IsVisible="{Binding ShowLocalBaseBranch}"
                                   VerticalAlignment="Center"
                                   Text="Base Branch:" />
                        <ComboBox x:Name="LocalBaseBranchComboBox"
                                  Grid.Column="4"
                                  Width="220"
                                  IsVisible="{Binding ShowLocalBaseBranch}"
                                  ItemsSource="{Binding LocalBaseBranchOptions}"
                                  SelectedItem="{Binding LocalBaseBranch, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="6"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Margin="0,12,0,0"
                          ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                        <Button x:Name="PrepareReviewButton"
                                Grid.Column="0"
                                Classes="accent neon"
                                Command="{Binding PrepareReviewCommand}"
                                IsEnabled="{Binding CanPrepareReview}"
                                Content="{Binding PrepareReviewButtonText}" />
                        <ProgressBar Grid.Column="1" x:Name="BusyIndicatorSpinner"
                                     Width="120"
                                     Margin="8,0"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding IsBusy}"
                                     IsIndeterminate="{Binding BusyProgressIsIndeterminate}"
                                     Maximum="{Binding BusyProgressMaximum}"
                                     Value="{Binding BusyProgressValue}" />
                        <Button x:Name="CancelProcessingButton"
                                Grid.Column="2"
                                Margin="0,0,8,0"
                                Classes="neon"
                                Padding="8"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsBusy}"
                                IsEnabled="{Binding CanCancelProcessing}"
                                Command="{Binding CancelProcessingCommand}"
                                ToolTip.Tip="Cancel current operation">
                            <Grid>
                                <materialIcons:MaterialIcon x:Name="CancelProcessingIcon"
                                                            IsVisible="{Binding !ShowCancelStoppingText}"
                                                            Width="18"
                                                            Height="18"
                                                            Kind="Cancel" />
                                <TextBlock x:Name="CancelProcessingStoppingTextBlock"
                                           IsVisible="{Binding ShowCancelStoppingText}"
                                           Text="Stopping..." />
                            </Grid>
                        </Button>
                        <Button x:Name="OpenSolutionButton"
                                Grid.Column="4"
                                Classes="neon"
                                Padding="12,8"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Command="{Binding OpenSolutionCommand}"
                                IsEnabled="{Binding CanOpenSolution}"
                                Content="Open Solution" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Classes="zone neonHero"
                    Background="{DynamicResource ZoneTertiaryBrush}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Row="0"
                               Margin="0,0,0,8"
                               Text="{Binding StatusText}" />
                    <ListBox x:Name="LogListBox"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Styles>
                            <Style Selector="ListBox#LogListBox ListBoxItem">
                                <Setter Property="Padding" Value="2" />
                                <Setter Property="Margin" Value="0" />
                            </Style>
                            <Style Selector="ListBox#LogListBox Button.logCopyButton">
                                <Setter Property="Width" Value="24" />
                                <Setter Property="Padding" Value="4,1" />
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="VerticalAlignment" Value="Top" />
                            </Style>
                            <Style Selector="ListBox#LogListBox ListBoxItem:pointerover Button.logCopyButton">
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Text}"
                                               Foreground="{Binding Foreground}"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas, Courier New, monospace" />
                                    <Button Grid.Column="1"
                                            Classes="logCopyButton"
                                            Margin="6,0,16,0"
                                            Command="{Binding #MainWindowRoot.CopyLogLineCommand}"
                                            CommandParameter="{Binding .}"
                                            VerticalContentAlignment="Center"
                                            ToolTip.Tip="Copy line"
                                            Content="⧉" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </dialogHostAvalonia:DialogHost>
</Window>
