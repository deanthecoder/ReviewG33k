<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d"
        x:Class="ReviewG33k.Views.MainWindow"
        Width="980" Height="700"
        MinWidth="880" MinHeight="520"
        Icon="/Assets/app.ico"
        Title="ReviewG33k">
    <dialogHostAvalonia:DialogHost x:Name="Host"
                                   OverlayBackground="#AA000000">
        <Grid Margin="18" RowDefinitions="Auto,Auto,*">
            <Border Grid.Row="0"
                    Margin="0,0,0,12"
                    Classes="zone neonFrame"
                    Background="{DynamicResource ZonePrimaryBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Classes="sectionTitle"
                               Text="ReviewG33k" />
                    <TextBlock
                        Text="Prepare Bitbucket pull requests for local review by creating an isolated checkout without changing your current working repo."
                        Opacity="0.9"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,0,0,12"
                    Classes="zone neonFrame"
                    Background="{DynamicResource ZoneSecondaryBrush}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Text="Repo Root Folder:" />
                    <TextBox x:Name="RepositoryRootTextBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             MinWidth="480"
                             Watermark="Example: C:\source" />
                    <Button Grid.Row="0"
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            Classes="neon"
                            Width="40"
                            Padding="8"
                            Click="BrowseRepositoryRootButton_OnClick"
                            ToolTip.Tip="Browse folder">
                        <materialIcons:MaterialIcon Width="18"
                                                    Height="18"
                                                    Kind="FolderSearchOutline" />
                    </Button>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,10,12,0"
                               VerticalAlignment="Center"
                               Text="Review Mode:" />
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="0,10,0,0"
                                Spacing="8"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Text="PR" />
                        <ToggleSwitch x:Name="ReviewModeToggleSwitch"
                                      VerticalAlignment="Center"
                                      Checked="ReviewModeToggleSwitch_OnChanged"
                                      Unchecked="ReviewModeToggleSwitch_OnChanged"
                                      OnContent=""
                                      OffContent="" />
                        <TextBlock VerticalAlignment="Center" Margin="-8,0,0,0"
                                   Text="Local" />
                    </StackPanel>

                    <TextBlock x:Name="PullRequestUrlLabelTextBlock"
                               Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,10,12,0"
                               VerticalAlignment="Center"
                               Text="Pull Request URL:" />
                    <TextBox x:Name="PullRequestUrlTextBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,10,0,0"
                             DragDrop.AllowDrop="True"
                             Watermark="Paste or drop a Bitbucket PR URL" />
                    <Button x:Name="OpenPullRequestButton"
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="10,10,0,0"
                            Classes="neon"
                            Padding="12,8"
                            Click="OpenPullRequestButton_OnClick"
                            Content="Open PR" />

                    <TextBlock x:Name="PullRequestPreviewTextBlock"
                               Grid.Row="3"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,8,0,0"
                               Opacity="0.9"
                               IsVisible="False" />

                    <TextBlock x:Name="PullRequestMetadataTextBlock"
                               Grid.Row="4"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Margin="0,4,0,0"
                               Opacity="0.78"
                               IsVisible="False"
                               TextWrapping="Wrap" />

                    <Grid x:Name="LocalReviewOptionsGrid"
                          Grid.Row="5"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="0,12,0,0"
                          ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                          IsVisible="False">
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Text="Local Repo Folder:" />
                        <TextBox x:Name="LocalRepositoryFolderTextBox"
                                 Grid.Column="1"
                                 MinWidth="360"
                                 Watermark="Example: C:\source\MyRepo" />
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Classes="neon"
                                Width="40"
                                Padding="8"
                                Click="BrowseLocalRepositoryButton_OnClick"
                                ToolTip.Tip="Browse folder">
                            <materialIcons:MaterialIcon Width="18"
                                                        Height="18"
                                                        Kind="FolderSearchOutline" />
                        </Button>
                        <TextBlock Grid.Column="3"
                                   Margin="14,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="Base Branch:" />
                        <TextBox x:Name="LocalBaseBranchTextBox"
                                 Grid.Column="4"
                                 Width="140"
                                 Watermark="main" />
                    </Grid>

                    <Grid Grid.Row="6"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="0,12,0,0"
                          ColumnDefinitions="Auto,Auto,*,Auto">
                        <Button x:Name="PrepareReviewButton"
                                Grid.Column="0"
                                Classes="accent neon"
                                Padding="14,8"
                                Click="PrepareReviewButton_OnClick"
                                Content="Review PR" />
                        <ProgressBar Grid.Column="1" x:Name="BusyIndicatorSpinner"
                                     Width="120"
                                     Margin="8,0"
                                     VerticalAlignment="Center"
                                     IsVisible="False"
                                     IsIndeterminate="True" />
                        <Button x:Name="OpenSolutionButton"
                                Grid.Column="3"
                                Classes="neon"
                                Padding="12,8"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Click="OpenSolutionButton_OnClick"
                                IsEnabled="False"
                                Content="Open Solution" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Classes="zone neonHero"
                    Background="{DynamicResource ZoneTertiaryBrush}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Row="0"
                               Margin="0,0,0,8"
                               Text="Ready." />
                    <ListBox x:Name="LogListBox"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Styles>
                            <Style Selector="ListBox#LogListBox ListBoxItem">
                                <Setter Property="Padding" Value="2" />
                                <Setter Property="Margin" Value="0" />
                            </Style>
                            <Style Selector="ListBox#LogListBox Button.logCopyButton">
                                <Setter Property="Width" Value="24" />
                                <Setter Property="Padding" Value="4,1" />
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="VerticalAlignment" Value="Top" />
                            </Style>
                            <Style Selector="ListBox#LogListBox ListBoxItem:pointerover Button.logCopyButton">
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="IsHitTestVisible" Value="True" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Text}"
                                               Foreground="{Binding Foreground}"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas, Courier New, monospace" />
                                    <Button Grid.Column="1"
                                            Classes="logCopyButton"
                                            Margin="6,0,16,0"
                                            Click="CopyLogLineButton_OnClick"
                                            VerticalContentAlignment="Center"
                                            ToolTip.Tip="Copy line"
                                            Content="⧉" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </dialogHostAvalonia:DialogHost>
</Window>
