<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
        mc:Ignorable="d"
        x:Class="ReviewG33k.Views.MainWindow"
        Width="980"
        Height="700"
        MinWidth="760"
        MinHeight="520"
        Icon="/Assets/app.ico"
        Title="ReviewG33k">
  <dialogHostAvalonia:DialogHost x:Name="Host"
                                 OverlayBackground="#AA000000">
    <Grid Margin="18" RowDefinitions="Auto,Auto,*">
      <Border Grid.Row="0"
              Margin="0,0,0,12"
              Classes="zone"
              Background="{DynamicResource ZonePrimaryBrush}">
        <StackPanel Spacing="6">
          <TextBlock Classes="sectionTitle"
                     Text="ReviewG33k" />
          <TextBlock Text="Prepare Bitbucket pull requests for local review by creating an isolated checkout without changing your current working repo."
                     Opacity="0.9"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Grid.Row="1"
              Margin="0,0,0,12"
              Classes="zone"
              Background="{DynamicResource ZoneSecondaryBrush}">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
              ColumnDefinitions="Auto,*,Auto">
          <TextBlock Grid.Row="0"
                     Grid.Column="0"
                     Margin="0,0,12,0"
                     VerticalAlignment="Center"
                     Text="Repo Root Folder:" />
          <TextBox x:Name="RepositoryRootTextBox"
                   Grid.Row="0"
                   Grid.Column="1"
                   MinWidth="480"
                   Watermark="Example: C:\source" />
          <Button Grid.Row="0"
                  Grid.Column="2"
                  Margin="10,0,0,0"
                  Padding="12,8"
                  Click="BrowseRepositoryRootButton_OnClick"
                  Content="Browse..." />

          <TextBlock Grid.Row="1"
                     Grid.Column="0"
                     Margin="0,10,12,0"
                     VerticalAlignment="Center"
                     Text="Pull Request URL:" />
          <TextBox x:Name="PullRequestUrlTextBox"
                   Grid.Row="1"
                   Grid.Column="1"
                   Margin="0,10,0,0"
                   DragDrop.AllowDrop="True"
                   Watermark="Paste or drop a Bitbucket PR URL" />
          <Button x:Name="OpenPullRequestButton"
                  Grid.Row="1"
                  Grid.Column="2"
                  Margin="10,10,0,0"
                  Padding="12,8"
                  Click="OpenPullRequestButton_OnClick"
                  Content="Open PR" />

          <TextBlock x:Name="PullRequestPreviewTextBlock"
                     Grid.Row="2"
                     Grid.Column="1"
                     Grid.ColumnSpan="2"
                     Margin="0,8,0,0"
                     Opacity="0.9"
                     IsVisible="False" />

          <StackPanel Grid.Row="3"
                      Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Margin="0,12,0,0"
                      Orientation="Horizontal"
                      Spacing="10">
            <Button x:Name="PrepareReviewButton"
                    Classes="accent"
                    Padding="14,8"
                    Click="PrepareReviewButton_OnClick"
                    Content="Prepare Review Checkout" />
            <CheckBox x:Name="AutoOpenSolutionCheckBox"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Content="Open highest-level .sln automatically" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="2"
              Classes="zone"
              Background="{DynamicResource ZoneTertiaryBrush}">
        <Grid RowDefinitions="Auto,*">
          <TextBlock x:Name="StatusTextBlock"
                     Grid.Row="0"
                     Margin="0,0,0,8"
                     Text="Ready." />
          <TextBox x:Name="LogTextBox"
                   Grid.Row="1"
                   AcceptsReturn="True"
                   IsReadOnly="True"
                   TextWrapping="Wrap"
                   FontFamily="Consolas, Courier New, monospace" />
        </Grid>
      </Border>
    </Grid>
  </dialogHostAvalonia:DialogHost>
</Window>
